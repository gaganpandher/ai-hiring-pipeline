# ─── App ──────────────────────────────────────────────────
APP_NAME=AI Hiring Pipeline
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=true

# ─── MySQL ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=hiring_db
MYSQL_USER=hiring_user
MYSQL_PASSWORD=hiring_pass
MYSQL_HOST=mysql
MYSQL_PORT=3306
DATABASE_URL=mysql+aiomysql://hiring_user:hiring_pass@mysql:3306/hiring_db

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_APPLICATIONS=applications
KAFKA_TOPIC_SCORING_RESULTS=scoring-results
KAFKA_TOPIC_BIAS_ALERTS=bias-alerts
KAFKA_TOPIC_AUDIT_LOG=audit-log
KAFKA_TOPIC_NOTIFICATIONS=notifications
KAFKA_TOPIC_RECRUITER_ACTIONS=recruiter-actions

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── File Storage ─────────────────────────────────────────
STORAGE_BACKEND=local       # local | s3
UPLOAD_DIR=/app/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
UPLOAD_DIR = C:\AI\2026\ai-hiring-pipeline\backend\app\uploads\
